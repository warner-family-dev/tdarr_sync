########################################
# Sonarr API Configuration
########################################

# URL for your Sonarr instance (including port)
# Example: http://192.168.1.101:8989
SONARR_URL=http://192.168.4.102:8989
# Sonarr API key (found in Sonarr web UI under Settings > General)
SONARR_API_KEY=4bf091c3808341b2a01afc85224c06df
# Optional: Only process items with this Sonarr tag name
# Leave blank to process all items
SONARR_TAG_NAME=transcode

########################################
# Paths for Tdarr Processing
########################################

# Base directory for your server's file system (often "/" unless chrooted)
BASE_DIR=/mnt/video/TV
# Directory where Tdarr should look for input files
TDARR_INPUT_DIR=/mnt/video/transcode/input
# Directory where Tdarr will place processed output files
TDARR_OUTPUT_DIR=/mnt/video/transcode/complete
# The root path Sonarr uses in its file paths (e.g. /tv) - Found in Sonnarr web UI under Settings > Media Management, scroll down to "Root Folders"
# Optional: Will use /tv if blank
SONARR_BASE_PATH=/tv/TV
# The local path on the remote machine where the media files are mounted
# Optional, default /mnt/media-videos
LOCAL_MOUNT_BASE_PATH=/mnt/video/TV
# DB file to store previously processed files
STATE_DB_FILE=sonarr_tdarr_state.db

########################################
# Backup Settings
########################################

# Make a backup and rename original files with .{backup_suffix} tag (True/False)
# Default is True, set to False to disable backups
RENAME_ORIGINAL_FILES=True
# File suffix to append to backups
# Default is .orig, can be changed to any suffix you prefer
BACKUP_SUFFIX=.orig
# Move .original files after renaming (True/False)
MOVE_ORIGINAL_FILES=False
# Location to move .original files (if MOVE_ORIGINAL_FILES=True)
MOVE_ORIGINAL_FILES_DEST=/mnt/originals_archive
# Delete .original files (True/False)
DELETE_ORIGINAL_FILES=False
# Days to keep before deleting .original files (0 = immediate)
DELETE_ORIGINAL_FILES_DAYS=30

########################################
# Telegram Bot Notifications
########################################

# Telegram bot API token for sending alerts
# Leave blank if you don't use Telegram notifications
TELEGRAM_BOT_TOKEN=6887808443:AAF5EBWkEIa-6pZ3DxoE07YcTypeJkf-JHY
# Telegram chat ID for the bot to send messages to
TELEGRAM_CHAT_ID=-1001993874601


########################################
# Logging Configuration
########################################

# Path to the log file
# Default if blank is /var/log/sonarr_tdarr_sync/sonarr_tdarr_sync.log
LOG_FILE=/opt/tdarr_sync/logs/tdarr_sync.log
# Max size (in bytes) before the log file is rotated
# Optional, default 10MB
LOG_MAX_BYTES=1048576
# Number of rotated log files to keep
#Optional, default 3
LOG_BACKUP_COUNT=3
