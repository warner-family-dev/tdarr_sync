# Base runtime
TZ=America/Chicago
PUID=1000
PGID=1000

# Networking
API_PORT=8000
WEB_PORT=3000

# Host mounts (update to match your environment)
SONARR_LIBRARY_MOUNT=/mnt/media/library
RADARR_LIBRARY_MOUNT=/mnt/media/movies
# Backward-compatible fallback if SONARR_LIBRARY_MOUNT is unset
HOST_LIBRARY_MOUNT=/mnt/media/library
HOST_TDARR_INPUT=/mnt/tdarr/input
HOST_TDARR_OUTPUT=/mnt/tdarr/output
HOST_ARCHIVE_DIR=/mnt/tdarr/archive
TDARR_SYNC_DATA_DIR=./data
TDARR_SYNC_LOG_DIR=./logs

# Tdarr Sync configuration (paths are inside the containers)
STATE_DB_FILE=/data/sonarr_tdarr_state.db
SONARR_URL=http://sonarr:8989
SONARR_API_KEY=replace-me
# Legacy fallback tag used only when UI routing rules are empty
SONARR_TAG_NAME=transcode
BASE_DIR=/media/library
TDARR_INPUT_DIR=/media/tdarr/input
TDARR_OUTPUT_DIR=/media/tdarr/output
SONARR_BASE_PATH=/mnt/media/library
LOCAL_MOUNT_BASE_PATH=/media/library
RADARR_URL=http://radarr:7878
RADARR_API_KEY=
# Legacy fallback tag used only when UI routing rules are empty
RADARR_TAG_NAME=transcode
RADARR_BASE_PATH=/mnt/media/movies
RADARR_LOCAL_MOUNT_BASE_PATH=/media/radarr_library
RENAME_ORIGINAL_FILES=true
BACKUP_SUFFIX=.orig
MOVE_ORIGINAL_FILES=true
MOVE_ORIGINAL_FILES_DEST=/media/archive
DELETE_ORIGINAL_FILES=true
DELETE_ORIGINAL_FILES_DAYS=30
RUNTIME_SETTINGS_FILE=/data/runtime_settings.json

# Restore dashboard controls
RESTORE_ADMIN_PASSWORD=

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Manual sync (used by cron or ad-hoc runs)
SYNC_DRY_RUN=false
SYNC_PROGRESS_FILE=/data/sync_progress.json

# API service
SYNC_SCRIPT_PATH=/app/tdarr_sync.py
SYNC_PYTHON_EXECUTABLE=python
# Web client proxy target (used by Next.js rewrites)
NEXT_BACKEND_ORIGIN=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Logging configuration
LOG_FILE=/logs/tdarr_sync.log

# Optional build/version metadata for header display
APP_GIT_VERSION=
APP_GIT_COMMIT_DATE=
APP_GIT_COMMIT_SHA=
